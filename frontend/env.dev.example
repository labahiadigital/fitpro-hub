# =============================================================================
# Trackfiz FRONTEND – Plantilla .env para entorno DEV
# -----------------------------------------------------------------------------
# IMPORTANTE: las variables VITE_* son de BUILD-TIME. En Coolify deben ir como
# "Build Arguments" del recurso `trackfiz-dev-frontend`, NO como "Environment
# Variables". Si las pones como env, Vite no las verá.
# =============================================================================

# Apunta al backend de DEV
VITE_API_URL=https://preapi.trackfiz.com/api/v1

# Activa el banner amarillo "DEV_MODE" en el header de la app.
# El banner también se activa automáticamente si el hostname empieza por
# preapp/preapi/dev. o es localhost, así que esta variable es belt-and-suspenders.
VITE_APP_ENV=development

# Stripe (modo TEST). Ojo: en el codebase aparecía una key con prefijo
# `sb_publishable_` que es formato SUPABASE, no Stripe. La de Stripe empieza por
# `pk_test_...` (test) o `pk_live_...` (prod). Aquí debe ir la de TEST.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_test_publishable_key

# --- Opcional: solo si el frontend acaba usando el cliente Supabase JS ------
# (hoy NO se usa, todo va por el backend, pero queda preparado)
VITE_SUPABASE_URL=https://girvemeyzfctxtcmhrup.supabase.co
