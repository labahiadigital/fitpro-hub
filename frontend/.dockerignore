# Environment files — never bundle local config into the image
.env
.env.*
.env.local
.env.development
.env.production

# Build outputs & deps (regenerated inside container)
node_modules/
dist/
build/
.vite/

# Testing / coverage
coverage/
.nyc_output/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# VCS
.git/
.gitignore

# Docker
.dockerignore
Dockerfile*

# Logs / misc
*.log
*.pid
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local cache
.turbo/
.cache/
