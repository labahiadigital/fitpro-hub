# =============================================================================
# Trackfiz BACKEND – Plantilla .env para entorno DEV (rama `dev` / preapi.trackfiz.com)
# -----------------------------------------------------------------------------
# Cómo usarla:
#   - En LOCAL: copia este archivo a `backend/.env.dev` (gitignored) y rellena
#     los placeholders con valores reales. Carga con tu launcher o
#     `--env-file backend/.env.dev`.
#   - En COOLIFY: pega cada variable como Environment Variable de los recursos
#     `trackfiz-dev-backend`, `trackfiz-dev-celery-worker` y
#     `trackfiz-dev-celery-beat`.
#
# Toda variable marcada con  ⚠️ DEV  cambia respecto a producción y NO debe
# reutilizar el valor de prod.
# =============================================================================

# --- Application -------------------------------------------------------------
APP_NAME=Trackfiz
APP_ENV=development
DEBUG=true

# ⚠️ DEV — generar uno NUEVO (no reutilizar el de prod):
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=__GENERAR_NUEVO_PARA_DEV__

# --- Supabase (proyecto trackfiz-dev) ---------------------------------------
# ⚠️ DEV — proyecto separado de producción
SUPABASE_URL=https://girvemeyzfctxtcmhrup.supabase.co
# anon key es PÚBLICA por diseño, OK incluirla:
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImdpcnZlbWV5emZjdHh0Y21ocnVwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc2NDgxMDgsImV4cCI6MjA5MzIyNDEwOH0.tzLb-7owgVs6M7kdovnCy_a-c5PIeQp8dXNWMgqdj3c
# Settings → API → service_role secret (proyecto trackfiz-dev)
SUPABASE_SERVICE_KEY=__OBTENER_DEL_DASHBOARD_TRACKFIZ_DEV__
# Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=__OBTENER_DEL_DASHBOARD_TRACKFIZ_DEV__

# --- Database (Supabase Pooler EU-WEST-3) -----------------------------------
# ⚠️ DEV — sustituye [DB_PASSWORD] por el password del proyecto trackfiz-dev
# (Settings → Database → Connection Pooling → Transaction).
DATABASE_URL=postgresql://postgres.girvemeyzfctxtcmhrup:[DB_PASSWORD]@aws-1-eu-west-3.pooler.supabase.com:6543/postgres

# --- Sync nocturno PROD → DEV (solo entorno dev) -----------------------------
# Activa la tarea Celery `sync-supabase-prod-to-dev` que se ejecuta a las
# 04:00 Europe/Madrid (definida en app/celery_app.py). Por seguridad la tarea
# aborta si APP_ENV=production o si la URL destino apunta al proyecto de prod.
ENABLE_DB_SYNC=true
# DATABASE_URL del proyecto Supabase de PROD (lectura). Sustituye [PROD_DB_PASSWORD]:
PROD_DATABASE_URL=postgresql://postgres.ougfmkbjrpnjvujhuuyy:[PROD_DB_PASSWORD]@aws-1-eu-west-3.pooler.supabase.com:6543/postgres
# DATABASE_URL del proyecto Supabase de DEV (escritura). Si está vacío, usa DATABASE_URL.
DEV_DATABASE_URL=
# Tablas excluidas del sync (separadas por comas). Defaults seguros:
DB_SYNC_EXCLUDE_TABLES=alembic_version,google_calendar_tokens
# Hook SQL opcional que se ejecuta tras el sync (en la BD de dev). Útil para
# resetear passwords / anonimizar. Plantilla en
# scripts/sync_supabase_post_dev.example.sql.
DB_SYNC_POST_SQL_FILE=

# --- Redis (servicio dev en Coolify) ----------------------------------------
# ⚠️ DEV — usar el servicio Redis del entorno dev, NO el de prod
REDIS_URL=redis://trackfiz-dev-redis:6379/0
CELERY_BROKER_URL=redis://trackfiz-dev-redis:6379/0
CELERY_RESULT_BACKEND=redis://trackfiz-dev-redis:6379/0

# --- URLs públicas (rama dev) -----------------------------------------------
# ⚠️ DEV
FRONTEND_URL=https://preapp.trackfiz.com
BACKEND_PUBLIC_URL=https://preapi.trackfiz.com

# ⚠️ DEV — añade aquí cualquier dominio dev que tengas que soportar
CORS_ORIGINS=https://preapp.trackfiz.com,http://localhost:5173

# --- Auth cookies ------------------------------------------------------------
AUTH_COOKIE_NAME=tf_refresh
# Vacío → cookie host-only (recomendado, NO comparte sesión con prod):
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

# --- Stripe (mismo modo TEST que prod, pero webhook diferente) --------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# ⚠️ DEV — crear webhook nuevo en Stripe Dashboard apuntando a:
#   https://preapi.trackfiz.com/api/v1/payments/webhook
STRIPE_WEBHOOK_SECRET=whsec_dev_webhook_secret

# --- Redsys (TPV, modo test) ------------------------------------------------
# El callback URL se construye con BACKEND_PUBLIC_URL → ya queda apuntando a
# preapi.trackfiz.com. Usa credenciales de Redsys TEST.
REDSYS_MERCHANT_CODE=__OBTENER_DEL_PORTAL_REDSYS_TEST__
REDSYS_SECRET_KEY=__OBTENER_DEL_PORTAL_REDSYS_TEST__
REDSYS_TERMINAL=001
REDSYS_ENVIRONMENT=test

# --- SeQura ------------------------------------------------------------------
SEQURA_USER=__OBTENER_DE_SEQURA_SANDBOX__
SEQURA_PASSWORD=__OBTENER_DE_SEQURA_SANDBOX__
SEQURA_MERCHANT_ID=__OBTENER_DE_SEQURA_SANDBOX__
SEQURA_ENDPOINT=https://sandbox.sequrapi.com
SEQURA_ASSET_KEY=__OBTENER_DE_SEQURA_SANDBOX__
SEQURA_ENVIRONMENT=sandbox

# --- Kapso (WhatsApp) --------------------------------------------------------
# ⚠️ DEV — RIESGO: si reutilizas la API key de prod, los webhooks de WhatsApp
# entrantes irán al BACKEND PRODUCTIVO (porque ahí están registrados).
# Recomendado: crea una cuenta/proyecto Kapso de pruebas y otro número de WhatsApp.
KAPSO_API_KEY=__USAR_API_KEY_DE_KAPSO_DEV_O_TEST__
KAPSO_API_BASE_URL=https://api.kapso.ai
# ⚠️ DEV — nuevo secret, distinto al de prod
KAPSO_WEBHOOK_SECRET=__GENERAR_NUEVO_PARA_DEV__

# --- Google Calendar (OAuth) -------------------------------------------------
# Las credenciales del cliente OAuth pueden ser las mismas de prod, PERO en
# Google Cloud Console → Credentials → OAuth 2.0 Client IDs tienes que añadir:
#   https://preapp.trackfiz.com/auth/google/callback
# como Authorized redirect URI.
GOOGLE_CLIENT_ID=__OBTENER_DE_GOOGLE_CLOUD_CONSOLE__
GOOGLE_CLIENT_SECRET=__OBTENER_DE_GOOGLE_CLOUD_CONSOLE__
GOOGLE_REDIRECT_URI=https://preapp.trackfiz.com/auth/google/callback

# --- Brevo (Emails transaccionales) ------------------------------------------
# ⚠️ DEV — RIESGO: con la misma API key, los emails dev SON REALES.
# Recomendado: API key separada en Brevo con sender "noreply-dev@trackfiz.com".
BREVO_API_KEY=__USAR_API_KEY_BREVO_DEV__
FROM_EMAIL=noreply-dev@trackfiz.com
FROM_NAME=Trackfiz (Dev)

# --- Cloudflare R2 (buckets dev — creados con wrangler) ---------------------
# Buckets ya creados:
#   - trackfiz-platform-dev
#   - trackfiz-workspaces-dev
# Custom domains públicos: configurarlos en R2 dashboard (no automatizable
# limpio con wrangler para dominios bajo zonas Cloudflare existentes).
R2_ACCOUNT_ID=__OBTENER_DE_CLOUDFLARE_R2_DASHBOARD__
R2_ACCESS_KEY_ID=__OBTENER_DE_CLOUDFLARE_R2_DASHBOARD__
R2_SECRET_ACCESS_KEY=__OBTENER_DE_CLOUDFLARE_R2_DASHBOARD__
R2_PLATFORM_BUCKET=trackfiz-platform-dev
R2_PLATFORM_PUBLIC_URL=https://platform-dev.trackfiz.com
R2_WORKSPACES_BUCKET=trackfiz-workspaces-dev
R2_WORKSPACES_PUBLIC_URL=https://workspaces-dev.trackfiz.com

# --- Encriptación de certificados FNMT (Verifactu) ---------------------------
# ⚠️ DEV — generar una clave NUEVA, distinta a la de prod
#   python -c "import os; print(os.urandom(32).hex())"
CERTIFICATE_ENCRYPTION_KEY=__GENERAR_NUEVA_PARA_DEV__
